{
  "version": 2,
  "builds": [
    {
      "src": "Backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Backend/server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "Frontend/assets/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "Frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "Frontend/js/$1"
    },
    {
      "src": "/(.*).html",
      "dest": "Frontend/$1.html"
    },
    {
      "src": "/",
      "dest": "Frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "Backend/server.js"
    }
  ]
}
